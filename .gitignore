data/*.csv
data/*.jpg
data/*.jpeg
data/*.png
data/*.log
data/mosaic.log
telemetry_*.csv
detections_*.csv
heartbeat_*.csv
confirmed_*.jpg
uncertain_*.jpg
missed_*.jpg
camera_test_*.jpg
test_frame.jpg

