# ═══════════════════════════════════════════════════════════════
# MOSAIC — .gitignore
# Modular Orchestrated Swarm with Adaptive Intelligence
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 🔐 SECURITY — NEVER COMMIT THESE (AWS IoT Certificates)
# ───────────────────────────────────────────────────────────────
certs/
*.pem
*.crt
*.key
*.pem.key
*.pem.crt
*-certificate.pem.crt
*-private.pem.key
*-public.pem.key
AmazonRootCA1.pem
AmazonRootCA3.pem

# ───────────────────────────────────────────────────────────────
# ⚙️  CONFIG — Contains credentials and endpoints
# ───────────────────────────────────────────────────────────────
config.py
config.py.save
config.py.save.*
*.save
*.save.*

# ───────────────────────────────────────────────────────────────
# 🤖 AI MODELS — Too large for GitHub (6MB+ each)
# ───────────────────────────────────────────────────────────────
models/*.pt
models/*.onnx
models/*.engine
models/*.tflite
models/*.pb
*.pt
*.onnx

# ───────────────────────────────────────────────────────────────
